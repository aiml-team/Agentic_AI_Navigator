<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Navigator</title>
  <link rel="icon" type="image/svg+xml" href="/static/Images/Navigator.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>

  <!-- ══ CSS FILES ══ -->
  <link rel="stylesheet" href="/static/css/base.css"/>
  <link rel="stylesheet" href="/static/css/components.css"/>
  <link rel="stylesheet" href="/static/css/pages.css"/>
  <link rel="stylesheet" href="/static/css/file_upload.css"/>
  <link rel="stylesheet" href="/static/css/analytics.css"/>
  <link rel="stylesheet" href="/static/css/feedback.css"/>
  <link rel="stylesheet" href="/static/css/tool_editor.css"/>
  <link rel="stylesheet" href="/static/css/scenario_library.css"/>
  <link rel="stylesheet" href="/static/css/admin_scenarios.css"/>
  <link rel="stylesheet" href="/static/css/auth.css"/>
</head>
<body>

<!-- ══════════════════════════════════════
     LOGIN SCREEN
══════════════════════════════════════ -->
<div id="authScreen">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon">🧭</div>
      <div class="auth-logo-text">AI Navigator</div>
    </div>
    <div class="auth-title">Welcome back</div>
    <div class="auth-subtitle">Sign in with your <strong>@bs.nttdata.com</strong> work email to access your personalised AI workspace.</div>
    <div class="auth-divider"></div>
    <form id="authForm" autocomplete="off">
      <label class="auth-label" for="authEmailInput">Work Email Address</label>
      <div class="auth-input-wrap">
        <span class="auth-input-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </span>
        <input class="auth-input" type="email" id="authEmailInput" placeholder="you@bs.nttdata.com" required autocomplete="off"/>
      </div>
      <div class="auth-error" id="authError"></div>
      <button class="auth-submit-btn" type="submit" id="authSubmitBtn">Sign In →</button>
    </form>
    <div class="auth-trust-row">
      <span class="auth-trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Secure access
      </span>
      <span class="auth-trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Role-based access
      </span>
      <span class="auth-trust-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Session only
      </span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     APP SHELL (hidden until login)
══════════════════════════════════════ -->
<div id="appShell" style="display:none;">

<!-- ══════════════════════════════════════
     HAMBURGER MENU DRAWER
══════════════════════════════════════ -->
<div class="menu-drawer-overlay" id="menuDrawerOverlay"></div>
<div class="menu-drawer" id="menuDrawer">
  <h3>Version 1.0.0</h3>
  <a href="https://itellicloud.sharepoint.com/:b:/r/sites/US-saleshub/Shared%20Documents/06-%20Digital%20Innovations%20Internal%20Documents/12-%20Artificial%20Intelligence%20and%20Machine%20Learning%20Projects/2026%20-%20AI%20Navigator/AI%20Navigator%20v1.0.0/Release%20Document%20-%20AI%20Navigator%20v1.0.0.pdf?csf=1&web=1&e=VJr3z3" class="menu-link">📄 Release document</a>
  <a href="https://itellicloud.sharepoint.com/:b:/r/sites/US-saleshub/Shared%20Documents/06-%20Digital%20Innovations%20Internal%20Documents/12-%20Artificial%20Intelligence%20and%20Machine%20Learning%20Projects/2026%20-%20AI%20Navigator/AI%20Navigator%20v1.0.0/Useer_manual_AI-Navigator.pdf?csf=1&web=1&e=tcxscn" class="menu-link">📖 User manual</a>
  <a href="#" class="menu-link fb-open-form-trigger">💬 Feedback Form</a>
  <button class="menu-link ss-open-trigger" id="drawerSuggestScenario" type="button">📝 Submit Scenario</button>

  <div class="drawer-admin-section" id="drawerAdminSection">
    <div class="drawer-admin-divider"></div>
    <div class="drawer-admin-label">Admin</div>
    <button class="menu-link" id="dropAnalytics">📊 Analytics Dashboard</button>
    <button class="menu-link" id="dropFeedbackView">💬 View Feedback</button>
    <button class="menu-link" id="dropToolChangeLog">📝 Tools Change Log</button>
    <button class="menu-link" id="dropPolicyUpload">📋 Upload Policy</button>
    <button class="menu-link" id="dropScenarios">📝 Scenarios</button>
  </div>
</div>

<!-- ══════════════════════════════════════
     SIDEBAR OVERLAY
══════════════════════════════════════ -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ══════════════════════════════════════
     HEADER
══════════════════════════════════════ -->
<header>
  <div class="header-content">
    <div class="hdr-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <img src="/static/Images/Logo-White.png" alt="Logo" class="hdr-logo" onerror="this.style.display='none'"/>
    </div>
    <div class="hdr-center">
      <div class="hdr-title-wrap">
        <img src="/static/Images/Navigator.svg" alt="AI Compass" class="hdr-compass-icon"/>
        <div class="hdr-title">AI Navigator</div>
      </div>
    </div>

    <div class="hdr-right-col">
        <span id="authUserBadge"></span>
        <div class="hdr-menu-wrap" id="hdrMenuWrap">
            <button class="hdr-toggle-btn" id="hdrToggleBtn" aria-label="Profile menu">
              <div class="hdr-profile-circle">
                <svg class="hdr-profile-svg" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
              </div>
            </button>
            <div class="hdr-dropdown" id="hdrDropdown">
              <button class="hdr-drop-item" id="authLogoutBtn">
                <span>🚪</span> Sign out
              </button>
            </div>
        </div>
    </div>
  </div>
</header>

<!-- ══════════════════════════════════════
     TAB NAVIGATION
══════════════════════════════════════ -->
<nav class="tab-navigation">
  <div class="tab-nav-inner">
    <button class="nav-tab active" data-page="home">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Home
    </button>
    <button class="nav-tab" data-page="promptlibrary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
      Scenario Library
    </button>
    <button class="nav-tab" data-page="tools">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
      </svg>
      AI Tools
    </button>
    <button class="nav-tab" data-page="history">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      History
    </button>
  </div>
</nav>

<!-- ══════════════════════════════════════
     SIDEBAR
══════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">
    <div class="sidebar-section">
      <div class="sidebar-label">Navigation</div>
      <button class="sidebar-item" data-page="analytics">📊 Analytics</button>
      <button class="sidebar-item" data-page="admin-scenarios">📝 Scenarios</button>
      <a href="#" class="menu-link">📄 Release document</a>
      <a href="#" class="menu-link">📖 User manual</a>
      <a href="#" class="menu-link fb-open-form-trigger">💬 Feedback Form</a>
      <a href="#" class="menu-link" id="sidebarFeedbackView">📋 View Feedbacks</a>
    </div>
    <!-- <div class="sidebar-section">
      <div class="sidebar-label">Quick Stats</div>
      <div class="sidebar-stat">
        <span class="sidebar-stat-label">Total Runs</span>
        <span class="sidebar-stat-val" id="sbTotalRuns">—</span>
      </div>
      <div class="sidebar-stat">
        <span class="sidebar-stat-label">Avg Rating</span>
        <span class="sidebar-stat-val" id="sbAvgRating">—</span>
      </div>
      <div class="sidebar-stat">
        <span class="sidebar-stat-label">Policies</span>
        <span class="sidebar-stat-val" id="sbPolicies">—</span>
      </div> -->
    </div>
  </div>
</aside>

<!-- ══════════════════════════════════════
     MAIN CONTENT
══════════════════════════════════════ -->
<main class="main" id="mainContent">

  <!-- ── HOME PAGE ── -->
  <section class="page active" id="page-home">
    <div class="home-outer" id="homeOuter">

      <!-- ══ CHAT PANEL (left, resizable) ══ -->
      <div class="chat-panel" id="chatPanel">
        <div class="chat-panel-inner">

          <!-- Chat header -->
          <div class="chat-panel-header">
            <div class="chat-panel-header-text">
              <div class="chat-panel-title">
                <div class="chat-status-dot"></div>
                AI Task Assistant
              </div>
              <div class="chat-panel-subtitle">Tell me what you need — I'll guide you</div>
            </div>
            <div class="chat-panel-header-actions">
              <button class="chat-reset-btn" id="chatResetBtn" title="Start a new chat and clear everything">New Task</button>
            </div>
          </div>

          <!-- Summary bar (shows extracted role / task_type) -->
          <div class="chat-summary-bar" id="chatSummaryBar">
            <div class="chat-summary-label">Gathered so far</div>
            <div class="chat-summary-tags" id="chatSummaryTags"></div>
          </div>

          <!-- Messages -->
          <div class="chat-messages" id="chatMessages"></div>

          <!-- Typing indicator -->
          <div class="chat-typing" id="chatTyping">
            <div class="chat-typing-dot"></div>
            <div class="chat-typing-dot"></div>
            <div class="chat-typing-dot"></div>
          </div>

          <!-- Ready banner -->
          <div class="chat-ready-banner" id="chatReadyBanner">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Task understood! Click <strong style="margin:0 3px;">Generate Response</strong> below to proceed.
          </div>

          <!-- Input + actions -->
          <div class="chat-input-area">
            <div class="chat-input-row">
              <textarea
                class="chat-input"
                id="chatInput"
                placeholder="Type your message…"
                rows="1"
                autocomplete="off"
              ></textarea>
              <button class="chat-send-btn" id="chatSendBtn" title="Send">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
            </div>
            <div class="chat-actions">
              <button class="chat-action-btn" id="chatSkipAllBtn" title="Skip remaining questions and proceed with what you've shared">
                Skip All &amp; Proceed
              </button>
              <button class="chat-action-btn primary-action" id="chatGenerateBtn" disabled title="Generate response using the gathered task info">
                <!-- <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> -->
                Generate Response
              </button>
            </div>
          </div>

        </div>
      </div>

      <!-- ══ DRAG HANDLE ══ -->
      <div class="home-drag-handle" id="homeDragHandle">
        <button class="chat-toggle-btn" id="chatToggleBtn" title="Toggle chat width">»</button>
      </div>

      <!-- Hidden inputs kept for JS compatibility — not shown to user -->
      <input type="hidden" id="selRole" />
      <input type="hidden" id="selTaskType" />
      <input type="hidden" id="userInput" />
      <span style="display:none" id="charCount">0</span>

      <!-- ══ RIGHT SIDE: results only ══ -->
      <div class="home-right" id="homeRight">

      <!-- RIGHT COLUMN: Steps -->
      <div>
        <div class="step-indicators">
          <div class="step-ind active" id="step-ind-1"><div class="step-num">1</div> Describe</div>
          <div class="step-ind" id="step-ind-2"><div class="step-num">2</div> Classify</div>
          <div class="step-ind" id="step-ind-3"><div class="step-num">3</div> Result</div>
        </div>

        <!-- STEP 1: Waiting -->
        <div class="step-panel active" id="step-1">
          <div class="card">
            <div class="card-bd">
              <div class="empty-state" style="padding:60px 20px">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                <p style="font-size:15px;font-weight:700;color:var(--text2);margin-bottom:6px">Ready to generate</p>
                <p>Chat with the assistant on the left — describe your task and click <strong>Generate Response</strong>.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- STEP 2: Processing -->
        <div class="step-panel" id="step-2">
          <div class="card">
            <div class="card-bd">
              <div class="processing-wrap">
                <div class="proc-icon">
                  <div class="proc-ring"></div>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </div>
                <div class="proc-steps" id="processingSteps">
                  <div class="proc-step" id="proc-1"><div class="proc-dot"></div><span>Classifying intent &amp; industry…</span></div>
                  <div class="proc-step" id="proc-2"><div class="proc-dot"></div><span>Matching role &amp; task context…</span></div>
                  <div class="proc-step" id="proc-3"><div class="proc-dot"></div><span>Recommending best AI tool…</span></div>
                  <div class="proc-step" id="proc-4"><div class="proc-dot"></div><span>Retrieving company policies…</span></div>
                  <div class="proc-step" id="proc-5"><div class="proc-dot"></div><span>Building optimised prompt…</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- STEP 3: Result -->
        <div class="step-panel" id="step-3">
          <div class="card">
            <div class="card-bd">



              <div id="policyBlockedBox" style="display:none"></div>

              <div class="result-meta" id="resultMeta"></div>
              <div id="toolRecBox"></div>
              <div id="policyFlagsBox"></div>
              <div id="alternativesBox"></div>

              <!-- Confidentiality notice — shown only when task is NOT blocked -->
              <div id="confidentialityNotice" style="display:none;align-items:flex-start;gap:10px;
                padding:11px 14px;border-radius:10px;margin-bottom:14px;
                background:#FFF8E6;border:1.5px solid #FCD34D;">
                <span style="font-size:17px;flex-shrink:0;margin-top:1px;">🔒</span>
                <div style="font-size:12.5px;color:#78350F;line-height:1.55;">
                  <strong style="display:block;margin-bottom:2px;font-size:13px;color:#92400E;">
                    Important Reminder — Handle with Care
                  </strong>
                  Do not enter confidential, personal, or commercially sensitive company data into AI tools.
                  Always use only <strong>approved tools</strong> from your organisation's registry, and
                  review all AI-generated output before sharing externally.
                </div>
              </div>

              <div class="output-tabs">
                <button class="output-tab active" data-out="prompt">📝 Prompt</button>
                <button class="output-tab" data-out="policies">🛡️ Policies Applied</button>
              </div>

              <div class="output-panel active" id="out-prompt">
              <div id="revisedBanner" class="revised-banner" style="display:none"></div>
              <!-- Edit / Copy / Save toolbar -->
              <div id="promptToolbar" style="display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap;">
                <button class="btn btn-secondary btn-sm" id="btnEditPrompt">&#9998; Edit</button>
                <button class="btn btn-secondary btn-sm" id="btnCopyPrompt">&#128203; Copy</button>
                <button class="btn btn-secondary btn-sm" id="btnSavePrompt">&#9733; Save to Favorites</button>
              </div>

              <div class="output-content code-block" id="resultPrompt"></div>

              <!-- Edit mode textarea — hidden by default -->
              <textarea id="promptEditArea" style="display:none;width:100%;min-height:340px;padding:14px;font-family:var(--mono);font-size:12px;line-height:1.5;border:2px solid var(--primary);border-radius:var(--radius-sm);background:var(--bg-white);color:var(--text);resize:vertical;outline:none;box-sizing:border-box;"></textarea>

              <div id="promptEditOk" style="display:none;margin-top:8px;display:none;">
                <button class="btn btn-primary btn-sm" id="btnPromptOk">&#10003; OK — Apply Changes</button>
                <button class="btn btn-ghost btn-sm" id="btnPromptCancelEdit" style="margin-left:6px;">Cancel</button>
              </div>

              <!-- Refinement box — CORLO Prompt tab only -->
              <div class="refinement-box" id="refinementBox">
                <div class="refinement-box-title">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Not happy with the prompt? Ask to revise it
                </div>
                <textarea class="refinement-input" id="refinementInput" placeholder="e.g. Make it shorter and more formal… or Focus more on risk analysis… or Add a section on budget considerations…"></textarea>
                <div class="refinement-actions">
                  <button class="btn btn-primary btn-sm" id="btnRefine">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    Revise Prompt
                  </button>
                  <span id="refineSpinner" style="display:none" class="char-count">Revising…</span>
                </div>
              </div>

              <!-- Feedback — CORLO Prompt tab only -->
              <div class="feedback-row">
                <span class="feedback-label">Rate this result:</span>
                <div class="stars" id="feedbackStars">
                  <button class="star" data-rating="1">★</button>
                  <button class="star" data-rating="2">★</button>
                  <button class="star" data-rating="3">★</button>
                  <button class="star" data-rating="4">★</button>
                  <button class="star" data-rating="5">★</button>
                </div>
                <div class="feedback-ml">
                  <button class="btn btn-ghost btn-sm" id="btnCopyOutput">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    Copy
                  </button>
                </div>
              </div>
            </div>

<div class="output-panel" id="out-policies">
  <div class="output-content html-content" id="resultPolicies"></div>
</div>

            </div>
          </div>
        </div>
      </div><!-- /right col of home-right -->
      </div><!-- /home-right -->
    </div><!-- /home-outer -->
  </section>

  <!-- ── HISTORY PAGE ── -->
  <section class="page" id="page-history">
    <div class="page-scroll-body">
    <div class="page-header">
      <div>
        <h2 class="page-title" id="historyPageTitle">Run History</h2>
        <p class="page-subtitle" id="historyPageSubtitle">Your previous orchestration runs with full audit logs.</p>
      </div>
      <button class="btn btn-secondary" id="btnRefreshHistory">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
        Refresh
      </button>
    </div>
    <div class="history-list" id="historyList">
      <div class="empty-state">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <p>No history yet.</p>
      </div>
    </div>
    </div>
  </section>

  <!-- ── AI TOOLS PAGE ── -->
  <section class="page" id="page-tools">
    <div class="tools-page">

      <!-- Sticky top bar -->
      <div class="tools-top-bar">
        <div class="tools-header">
          <div>
            <h2 class="tools-title">AI Tools Registry</h2>
            <p class="tools-subtitle">All available enterprise AI tools and their capabilities.</p>
          </div>
          <div class="tools-header-actions">
            <input type="search" id="toolsSearch" class="tools-search" placeholder="Search tools…" aria-label="Search tools">
            <button class="tools-register-btn" id="btnRegisterTool">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Register Tool
            </button>
          </div>
        </div>

        <!-- Toolbar row: view toggle left, category filter right -->
        <div class="tools-toolbar-row">
          <div class="tools-view-toggle">
            <button class="tools-view-btn active" id="btnTileView" title="Tile view">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Grid
            </button>
            <button class="tools-view-btn" id="btnRowView" title="List view">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
              List
            </button>
          </div>
          <div class="tools-toolbar-right">
            <label class="tools-filter-label" for="toolsCategoryFilter">Filter by Category:</label>
            <select id="toolsCategoryFilter" class="tools-cat-select">
              <option value="">All Categories</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Body: sidebar + content -->
      <div class="tools-body-scroll">
        <div class="tools-layout">

          <!-- Left sidebar -->
          <nav class="tools-sidebar">
            <div class="tools-side-section">
              <div class="tools-side-label">Navigate</div>
              <div id="toolsNavAll">
                <div class="tools-nav-item active" data-role="all">
                  <span class="tools-nav-dot" style="background:#3498db"></span>
                  <span class="tools-nav-label">All Tools</span>
                  <span class="tools-nav-count" id="toolsCountBadge">0</span>
                </div>
              </div>
            </div>
            <div class="tools-side-section">
              <div class="tools-side-label">What are you trying to do?</div>
              <div id="toolsNavRoles">
                <div class="tools-nav-item" data-role="sales">
                  <span class="tools-nav-dot" style="background:#8e44ad"></span>
                  <span class="tools-nav-label">Sales</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="consulting">
                  <span class="tools-nav-dot" style="background:#3498db"></span>
                  <span class="tools-nav-label">Consulting</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="hr">
                  <span class="tools-nav-dot" style="background:#27ae60"></span>
                  <span class="tools-nav-label">Human Resource</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="finance">
                  <span class="tools-nav-dot" style="background:#e67e22"></span>
                  <span class="tools-nav-label">Finance</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="marketing">
                  <span class="tools-nav-dot" style="background:#e74c3c"></span>
                  <span class="tools-nav-label">Marketing</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="ams">
                  <span class="tools-nav-dot" style="background:#16a085"></span>
                  <span class="tools-nav-label">AMS</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="developer">
                  <span class="tools-nav-dot" style="background:#2980b9"></span>
                  <span class="tools-nav-label">Developer</span>
                  <span class="tools-nav-count"></span>
                </div>
                <div class="tools-nav-item" data-role="operations">
                  <span class="tools-nav-dot" style="background:#7f8c8d"></span>
                  <span class="tools-nav-label">Operations</span>
                  <span class="tools-nav-count"></span>
                </div>
              </div>
            </div>
          </nav>

          <!-- Right content -->
          <div class="tools-content">
            <div class="tools-grid" id="toolsGrid">
              <div class="loading-spinner"><div class="spinner"></div></div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── ANALYTICS PAGE ── -->
  <section class="page" id="page-analytics">
    <div class="page-scroll-body">
    <div class="page-header">
      <div>
        <h2 class="page-title">Analytics</h2>
        <p class="page-subtitle">Usage insights and performance metrics.</p>
      </div>
      <button class="btn btn-secondary" id="btnRefreshAnalytics">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
        Refresh
      </button>
    </div>
    <div id="analyticsContent">
      <div class="loading-spinner"><div class="spinner"></div></div>
    </div>
    </div>
  </section>

  <!-- ── POLICIES PAGE ── -->
  <section class="page" id="page-policies">
    <div class="page-header">
      <div>
        <h2 class="page-title">Company Policies</h2>
        <p class="page-subtitle">Upload policy documents to guide AI tool recommendations and compliance.</p>
      </div>
    </div>
    <div class="policies-layout">
      <div class="upload-card">
        <div class="upload-zone" id="uploadZone">
          <div class="upload-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <p class="upload-title">Drop your policy file here</p>
          <p class="upload-hint">Supports .pdf and .docx files</p>
          <input type="file" id="policyFileInput" accept=".pdf,.docx" style="display:none"/>
          <button class="btn btn-secondary btn-sm" id="btnBrowseFile">Browse Files</button>
        </div>
        <div id="uploadStatus" style="margin-top:12px;"></div>
      </div>
      <div class="policies-list-card">
        <div class="card-header-row">
          <span class="card-title">Indexed Policies</span>
          <button class="btn btn-ghost btn-sm" id="btnRefreshPolicies">Refresh</button>
        </div>
        <div id="policiesList">
          <div class="loading-spinner"><div class="spinner"></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ADMIN SCENARIOS PAGE ── -->
  <section class="page" id="page-admin-scenarios">
    <div class="page-scroll-body">

      <div class="page-header">
        <div>
          <h2 class="page-title">Scenarios Admin</h2>
          <p class="page-subtitle">Review user-submitted scenario suggestions and manage the scenario log.</p>
        </div>
        <button class="btn btn-secondary" id="btnRefreshAdminScenarios">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
          Refresh
        </button>
      </div>

      <!-- Sub-tabs -->
      <div class="as-tabs">
        <button class="as-tab active" data-astab="review">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
          Scenario Review
          <span class="as-tab-badge" id="asPendingBadge">0</span>
        </button>
        <button class="as-tab" data-astab="log">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Scenario Log
        </button>
      </div>

      <!-- ── REVIEW PANEL ── -->
      <div class="as-panel active" data-aspanel="review">

        <div class="as-filters">
          <input class="as-search" type="text" id="asReviewSearch" placeholder="Search by title, group, keyword…" autocomplete="off"/>
        </div>

        <div id="asReviewList" class="as-card-list">
          <div class="as-loading"><div class="spinner"></div></div>
        </div>

        <div class="as-pagination" id="asReviewPagination" style="display:none;">
          <button class="as-page-btn" id="asReviewPrev">← Prev</button>
          <span class="as-page-info" id="asReviewPageInfo"></span>
          <button class="as-page-btn" id="asReviewNext">Next →</button>
        </div>
      </div>

      <!-- ── LOG PANEL ── -->
      <div class="as-panel" data-aspanel="log" style="display:none;">

        <div class="as-filters">
          <select class="as-select" id="asLogStatus">
            <option value="all">All Statuses</option>
            <option value="pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="rejected">Rejected</option>
          </select>
          <input class="as-search" type="text" id="asLogSearch" placeholder="Search title, group, keyword…" autocomplete="off"/>
        </div>

        <div id="asLogTable" class="as-table-wrap">
          <div class="as-loading"><div class="spinner"></div></div>
        </div>

        <div class="as-pagination" id="asLogPagination" style="display:none;">
          <button class="as-page-btn" id="asLogPrev">← Prev</button>
          <span class="as-page-info" id="asLogPageInfo"></span>
          <button class="as-page-btn" id="asLogNext">Next →</button>
        </div>
      </div>

    </div>
  </section>

  <!-- ── SCENARIO LIBRARY PAGE ── -->
  <section class="page" id="page-promptlibrary">
    <div class="sl-page">

      <!-- Sticky top bar -->
      <div class="sl-top-bar">

        <!-- Header row: title + search + actions -->
        <div class="sl-header">
          <div>
            <h2>Scenario Library</h2>
            <p class="sl-header-subtitle">Browse by group, filter by category, or search across all.</p>
          </div>
          <div class="sl-header-actions">
            <input type="search" id="slSearch" class="sl-search" placeholder="Search scenarios, roles, prompts…" aria-label="Search scenarios">
            <button class="sl-upload-btn" id="slRegisterScenarioBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Register Scenario
            </button>
          </div>
        </div>

        <!-- Horizontal Scenarios / Favorites tabs + Role filter on the right -->
        <div class="sl-subtab-bar">
          <div class="sl-subtab-tabs">
            <button class="sl-subtab-btn active" data-sltab="scenarios">Scenarios</button>
            <button class="sl-subtab-btn" data-sltab="favorites">Favorites</button>
          </div>
          <div class="sl-subtab-right">
            <label class="sl-role-label" for="slRoleFilter">Filter by Role:</label>
            <select id="slRoleFilter" class="sl-role-select">
              <option value="">All Roles</option>
            </select>
          </div>
        </div>

      </div><!-- /.sl-top-bar -->

      <!-- Body: sidebar + content -->
      <div class="sl-body-scroll">

        <!-- SCENARIOS PANEL -->
        <div class="sl-subtab-panel active" id="sl-panel-scenarios">

          <!-- Two-column layout: sidebar + main -->
          <div class="sl-layout">

            <!-- Left sidebar: mega-group navigation -->
            <nav class="sl-sidebar">
              <div class="sl-side-section">
                <div class="sl-side-label">Navigate</div>
                <div id="slMegaNav">
                  <!-- populated by JS -->
                  <div class="sl-nav-item active" data-mega="all">
                    <span class="sl-nav-dot" style="background:#3498db"></span>
                    <span class="sl-nav-label">All Scenarios</span>
                    <span class="sl-nav-count" id="slCountBadge">0</span>
                  </div>
                </div>
              </div>
              <div class="sl-side-section">
                <div class="sl-side-label">What are you trying to do?</div>
                <div id="slMegaNavGroups">
                  <!-- mega-group items populated by JS below the "All" item -->
                </div>
              </div>
            </nav>

            <!-- Right content -->
            <div class="sl-content">
              <div class="sl-loading" id="slLoading" style="display:none;">
                <div class="sl-spinner"></div>
                Loading scenarios…
              </div>
              <div id="slMainArea">
                <div class="sl-grid-heading" id="slGridHeading"></div>
                <div id="slScenarioGrid"></div>
                <div id="slScenarioEmpty" class="sl-empty hidden">
                  <div class="sl-empty-icon">🔎</div>
                  <h3>No scenarios found</h3>
                  <p>Try a different group, category, or search term.</p>
                </div>
              </div>
            </div>

          </div><!-- /.sl-layout -->
        </div><!-- /#sl-panel-scenarios -->

        <!-- FAVORITES PANEL -->
        <div class="sl-subtab-panel" id="sl-panel-favorites">
          <div class="sl-fav-grid" id="slFavGrid"></div>
          <div id="slFavEmpty" class="sl-empty hidden">
            <div class="sl-empty-icon">⭐</div>
            <h3>No favorites yet</h3>
            <p>Click <strong>☆ Save</strong> on any scenario card to add it here.</p>
          </div>
        </div>

      </div><!-- /.sl-body-scroll -->
    </div><!-- /.sl-page -->
  </section>

</main>

<!-- LOG MODAL -->
<div class="modal-overlay" id="logModal">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Run Log</h3>
      <button class="modal-close" id="btnCloseModal">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" id="logModalBody"></div>
  </div>
</div>

