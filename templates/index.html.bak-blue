<!-- TOAST -->
<div class="toast-container" id="toastContainer"></div>











<!-- ══════════════════════════════════════
     POLICY UPLOAD MODAL
══════════════════════════════════════ -->
<div class="fu-overlay" id="puOverlay"></div>
<div class="fu-modal" id="puModal">
  <div class="fu-modal-header">
    <span>📋 Upload Policy Document</span>
    <button class="fu-close-btn" id="puCloseBtn">✕</button>
  </div>
  <div class="fu-modal-body">
    <div class="fu-drop-zone" id="puDropZone">
      <div class="fu-drop-icon">📄</div>
      <div class="fu-drop-title">Drop your policy document here</div>
      <div class="fu-drop-sub">or click to browse — .pdf or .docx files accepted</div>
      <input type="file" id="puFileInput" accept=".pdf,.docx" hidden />
    </div>
    <div class="fu-file-info" id="puFileInfo" style="display:none">
      <span class="fu-file-name" id="puFileName"></span>
      <button class="fu-clear-btn" id="puClearBtn">✕</button>
    </div>
    <div class="fu-required-note">
      Uploaded documents will be indexed and used to guide AI responses and compliance checks.<br/>
      Supported formats: <code>.pdf</code>, <code>.docx</code>
    </div>
  </div>
  <div class="fu-modal-footer">
    <button class="fu-cancel-btn" id="puCancelBtn">Cancel</button>
    <button class="fu-upload-btn" id="puUploadBtn" disabled>Upload & Index</button>
  </div>
  <div class="fu-status" id="puStatus" style="display:none"></div>
</div>





<!-- ══════════════════════════════════════
     REGISTER SCENARIO MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="registerScenarioOverlay" role="dialog" aria-modal="true" aria-labelledby="registerScenarioTitle">
  <div class="te-modal" style="max-width:660px;">

    <!-- Header -->
    <div class="te-header">
      <div class="te-header-left">
        <div style="font-size:22px;">📚</div>
        <div>
          <div class="te-header-name" id="registerScenarioTitle">Register New Scenario</div>
          <div class="te-header-cat">Add a new scenario to the Scenario Library</div>
        </div>
      </div>
      <div class="te-header-right">
        <button class="te-close-btn" id="btnCloseRegisterScenario" aria-label="Close">✕</button>
      </div>
    </div>

    <!-- Tabs -->
    <div class="te-tabs">
      <button class="te-tab active" data-rstab="manual">✏️ Manual Input</button>
      <button class="te-tab"        data-rstab="fileupload">📂 File Upload</button>
    </div>

    <!-- Body -->
    <div class="te-body">

      <!-- MANUAL INPUT PANEL -->
      <div class="te-panel active" data-rspanel="manual">
        <div class="te-edit-body" style="padding:20px;">

          <div class="te-edit-note">
            ✏️ <strong>Manual entry</strong> — fill in the fields below and click Save Scenario.
          </div>

          <div class="te-form-grid">
            <div>
              <label class="te-label" for="rsTitle">Scenario Title <span class="te-hint">(required)</span></label>
              <input class="te-input" type="text" id="rsTitle" placeholder="e.g. Write a client proposal" autocomplete="off"/>
            </div>
            <div>
              <label class="te-label" for="rsMegaGroup">Group <span class="te-hint">(required)</span></label>
              <select class="te-input" id="rsMegaGroup">
                <option value="">— Select Group —</option>
              </select>
            </div>
            <div>
              <label class="te-label" for="rsCategory">Category <span class="te-hint">(required)</span></label>
              <select class="te-input" id="rsCategory">
                <option value="">— Select Category —</option>
              </select>
            </div>
            <div>
              <label class="te-label" for="rsPersona">Persona / Role <span class="te-hint">(required)</span></label>
              <select class="te-input" id="rsPersona">
                <option value="">— Select Persona / Role —</option>
              </select>
            </div>
            <div id="rsActivatePhaseRow" style="display:none;">
              <label class="te-label" for="rsActivatePhase">Activate Phase</label>
              <select class="te-input" id="rsActivatePhase">
                <option value="">— Select Phase —</option>
                <option value="Discover">Discover</option>
                <option value="Prepare">Prepare</option>
                <option value="Explore">Explore</option>
                <option value="Realize">Realize</option>
                <option value="Deploy">Deploy</option>
                <option value="Run">Run</option>
              </select>
            </div>
          </div>

          <div class="te-form-full" style="margin-top:4px;">
            <label class="te-label" for="rsScenario">Scenario / Prompt Body <span class="te-hint">(required)</span></label>
            <textarea class="te-textarea" id="rsScenario" rows="7" placeholder="Write the full scenario or prompt text here…"></textarea>
          </div>

          <div id="rsStatus" style="display:none;padding:10px 12px;border-radius:8px;font-size:13px;margin-top:12px;"></div>

        </div>
      </div>

      <!-- FILE UPLOAD PANEL (Excel / bulk upload) -->
      <div class="te-panel" data-rspanel="fileupload" style="display:none;">
        <div style="padding:24px 20px;">

          <div class="te-edit-note" style="background:#eff6ff;border-color:#bfdbfe;color:#1e40af;">
            📂 <strong>Bulk upload</strong> — upload an Excel file (.xlsx) to replace or extend the Scenario Library.
          </div>

          <div id="rsBulkDropZone" style="border:2px dashed var(--border);border-radius:12px;padding:32px 20px;text-align:center;cursor:pointer;transition:border-color .2s,background .2s;margin-top:16px;">
            <div style="font-size:36px;margin-bottom:8px;">📊</div>
            <div style="font-size:14px;font-weight:600;color:var(--text2);margin-bottom:4px;">Drop your Scenario Library Excel here</div>
            <div style="font-size:12px;color:var(--text3);margin-bottom:14px;">or click to browse — .xlsx files only</div>
            <button class="btn btn-secondary" id="btnBrowseBulkScenarios" type="button" style="font-size:12px;padding:6px 14px;">Browse File</button>
            <input type="file" id="rsBulkFileInput" accept=".xlsx,.xlsm,.xls" style="display:none"/>
          </div>

          <div id="rsBulkFileInfo" style="display:none;align-items:center;gap:10px;padding:10px 14px;border-radius:8px;background:var(--bg-secondary);border:1px solid var(--border);margin-top:12px;">
            <span style="font-size:13px;flex:1;" id="rsBulkFileName"></span>
            <button id="rsBulkClearBtn" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:14px;padding:2px 4px;" title="Remove">✕</button>
          </div>

          <div style="margin-top:14px;padding:10px 14px;border-radius:8px;background:var(--bg-secondary);border:1px solid var(--border);font-size:12px;color:var(--text3);line-height:1.6;">
            Required sheet: <code>Scenario Library</code> — Required columns: <code>Group</code>,
            <code>Category</code>, <code>Scenario Title</code>, <code>Persona / Role</code>, <code>Scenarios</code>
          </div>

          <div id="rsBulkStatus" style="display:none;margin-top:12px;padding:10px 14px;border-radius:8px;font-size:13px;"></div>

        </div>
      </div>

    </div><!-- /.te-body -->

    <!-- Footer -->
    <div class="te-footer">
      <div class="te-footer-left">
        <button class="te-btn te-btn-secondary" id="btnCancelRegisterScenario">Cancel</button>
      </div>
      <div class="te-footer-right" id="rsFooterRight">
        <button class="te-btn te-btn-primary" id="btnSaveRegisterScenario">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Scenario
        </button>
      </div>
    </div>

  </div>
</div>

<!-- SUGGEST SCENARIO MODAL -->
<div class="modal-overlay" id="suggestScenarioOverlay" role="dialog" aria-modal="true" aria-labelledby="suggestScenarioTitle">
  <div class="te-modal" style="max-width:660px;">

    <div class="te-header">
      <div class="te-header-left">
        <div style="font-size:22px;">📝</div>
        <div>
          <div class="te-header-name" id="suggestScenarioTitle">Submit Scenario</div>
          <div class="te-header-cat">Submit your idea — an admin will review before adding to the library</div>
        </div>
      </div>
      <div class="te-header-right">
        <button class="te-close-btn" id="btnCloseSuggestScenario" aria-label="Close">✕</button>
      </div>
    </div>

    <div class="te-body">
      <div class="te-panel active" data-rspanel="manual">
        <div class="te-edit-body" style="padding:20px;">

          <div class="te-edit-note">
            ✏️ <strong>Manual entry</strong> — fill in the fields below and click Submit Scenario.
          </div>

          <div class="te-form-grid">
            <div>
              <label class="te-label" for="ssTitle">Scenario Title <span class="te-hint">(required)</span></label>
              <input class="te-input" type="text" id="ssTitle" placeholder="e.g. Write a client proposal" autocomplete="off"/>
            </div>
            <div>
              <label class="te-label" for="ssMegaGroup">Group <span class="te-hint">(required)</span></label>
              <select class="te-input" id="ssMegaGroup">
                <option value="">— Select Group —</option>
              </select>
            </div>
            <div>
              <label class="te-label" for="ssCategory">Category <span class="te-hint">(required)</span></label>
              <select class="te-input" id="ssCategory">
                <option value="">— Select Category —</option>
              </select>
            </div>
            <div>
              <label class="te-label" for="ssPersona">Persona / Role <span class="te-hint">(required)</span></label>
              <select class="te-input" id="ssPersona">
                <option value="">— Select Persona / Role —</option>
              </select>
            </div>
            <div id="ssActivatePhaseRow" style="display:none;">
              <label class="te-label" for="ssActivatePhase">Activate Phase</label>
              <select class="te-input" id="ssActivatePhase">
                <option value="">— Select Phase —</option>
                <option value="Discover">Discover</option>
                <option value="Prepare">Prepare</option>
                <option value="Explore">Explore</option>
                <option value="Realize">Realize</option>
                <option value="Deploy">Deploy</option>
                <option value="Run">Run</option>
              </select>
            </div>
          </div>

          <div class="te-form-full" style="margin-top:4px;">
            <label class="te-label" for="ssScenario">Scenario / Prompt Body <span class="te-hint">(required)</span></label>
            <textarea class="te-textarea" id="ssScenario" rows="7" placeholder="Write the full scenario or prompt text here…"></textarea>
          </div>

          <div id="ssStatus" style="display:none;padding:12px 16px;border-radius:8px;font-size:13.5px;font-weight:600;margin-top:14px;line-height:1.5;"></div>

        </div>
      </div>
    </div>

    <div class="te-footer">
      <div class="te-footer-left">
        <button class="te-btn te-btn-secondary" id="btnCancelSuggestScenario">Cancel</button>
      </div>
      <div class="te-footer-right">
        <button class="te-btn te-btn-primary" id="btnSubmitSuggestScenario">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Submit Scenario
        </button>
      </div>
    </div>

  </div>
</div>

<!-- SCENARIO GENERATE MODAL -->
<div class="modal-overlay" id="scenarioGenModal">
  <div class="modal" style="max-width:720px;">
    <div class="modal-header">
      <h3 class="modal-title">⚡ Review & Edit Before Generate</h3>
      <button class="modal-close" id="btnCloseScenarioGenModal" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="modal-body">
      <p style="margin:0 0 10px;color:var(--text3);font-size:13px;line-height:1.4;">
        This template may include placeholders like <code>[topic]</code>. Update anything you want, then generate.
      </p>

      <div class="row2" style="margin-bottom:10px;">
        <div>
          <label class="field-label" for="scenarioRole">Role</label>
          <input type="text" id="scenarioRole" list="scenarioRoleList" placeholder="Select or type role..." autocomplete="off" />
          <datalist id="scenarioRoleList">
            <option value="Consultant / Manager"></option>
            <option value="Executive / Director"></option>
            <option value="Developer / Technical"></option>
            <option value="Business Analyst"></option>
            <option value="Sales / BD"></option>
            <option value="Marketing / Comms"></option>
            <option value="HR / People Ops"></option>
            <option value="Finance / Accounting"></option>
          </datalist>
        </div>
        <div>
          <label class="field-label" for="scenarioTaskType">Task Type</label>
          <input type="text" id="scenarioTaskType" list="scenarioTaskTypeList" placeholder="Select or type task type..." autocomplete="off" />
          <datalist id="scenarioTaskTypeList">
            <option value="Research &amp; Analysis"></option>
            <option value="Writing &amp; Docs"></option>
            <option value="Strategy &amp; Planning"></option>
            <option value="Data Analysis"></option>
            <option value="Code &amp; Dev"></option>
            <option value="Creative Content"></option>
            <option value="Communication"></option>
            <option value="Learning &amp; Training"></option>
            <option value="Process Automation"></option>
            <option value="Decision Support"></option>
          </datalist>
        </div>
      </div>

      <label class="field-label" for="scenarioDesc">Task Description</label>
      <textarea id="scenarioDesc" rows="8" style="width:100%;"></textarea>

      <div id="scenarioPlaceholderHint"
           style="display:none;margin-top:10px;padding:10px 12px;border:1px solid var(--border);border-radius:10px;background:var(--bg-secondary);font-size:13px;color:var(--text2);">
      </div>
    </div>

    <div class="modal-footer" style="padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;">
      <button class="btn btn-secondary" id="btnCancelScenarioGen">Cancel</button>
      <button class="btn btn-primary" id="btnConfirmScenarioGen">
        Generate Response
      </button>
    </div>
  </div>
</div>




<!-- ══════════════════════════════════════
     ENRICHED TASK SUGGESTION MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="enrichedOverlay">
  <div class="modal" style="max-width:660px;">

    <div class="modal-header">
      <h3 class="modal-title">✨ Review &amp; Edit Before Generate</h3>
      <button class="modal-close" id="enrichedBannerClose" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="modal-body">
      <p style="margin:0 0 14px;color:var(--text3);font-size:13px;line-height:1.5;">
        Based on your answers, here is an enriched task description. You can edit it before generating, or use the original.
      </p>

      <label class="field-label">Original Task</label>
      <div id="enrichedOrigText" style="
        padding:10px 12px;border-radius:var(--radius-sm);
        background:var(--bg-secondary);border:1px solid var(--border);
        font-size:12.5px;color:var(--text2);line-height:1.6;
        margin-bottom:14px;white-space:pre-wrap;
      "></div>

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
        <label class="field-label" for="enrichedDescText" style="margin:0;">Enriched Task Description</label>
        <button id="enrichedEditBtn" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 10px;">&#9998; Edit</button>
      </div>
      <div id="enrichedDescDisplay" style="
        padding:10px 12px;border-radius:var(--radius-sm);
        background:var(--bg-secondary);border:1px solid var(--border);
        font-size:13px;color:var(--text);line-height:1.6;
        white-space:pre-wrap;min-height:80px;
      "></div>
      <textarea id="enrichedDescText" rows="6" style="display:none;width:100%;"></textarea>
    </div>

    <div class="modal-footer" style="padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:10px;">
      <button class="btn btn-secondary" id="enrichedBannerOriginal">
        Use original instead
      </button>
      <button class="btn btn-primary" id="enrichedBannerUse">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Use this &amp; Generate
      </button>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════
     REGISTER TOOL MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="registerToolOverlay" role="dialog" aria-modal="true" aria-labelledby="registerToolTitle">
  <div class="te-modal" style="max-width:700px;">

    <!-- Header -->
    <div class="te-header">
      <div class="te-header-left">
        <div style="font-size:22px;">🛠</div>
        <div>
          <div class="te-header-name" id="registerToolTitle">Register New Tool</div>
          <div class="te-header-cat">Add a new tool to the AI Tools Registry</div>
        </div>
      </div>
      <div class="te-header-right">
        <button class="te-close-btn" id="btnCloseRegisterTool" aria-label="Close">✕</button>
      </div>
    </div>

    <!-- Tabs -->
    <div class="te-tabs">
      <button class="te-tab active" data-rttab="manual">✏️ Manual Input</button>
      <button class="te-tab"        data-rttab="fileupload">📂 File Upload</button>
    </div>

    <!-- Body -->
    <div class="te-body">

      <!-- MANUAL INPUT PANEL -->
      <div class="te-panel active" data-rtpanel="manual">
        <div class="te-edit-body" style="padding:20px;">

          <div class="te-edit-note">
            ✏️ <strong>Manual entry</strong> — fill in the fields below and click Save Tool.
          </div>
          <div id="rtEditModeNote" style="display:none;margin-bottom:12px;padding:10px 14px;border-radius:8px;font-size:13px;background:#fef9c3;border:1px solid #fde047;color:#713f12;">
            ✏️ You are editing an existing tool. Changes will update the registry.
          </div>

          <div class="te-form-grid">
            <div>
              <label class="te-label" for="rtToolName">Tool Name <span class="te-hint">(required)</span></label>
              <input class="te-input" type="text" id="rtToolName" placeholder="e.g. GitHub Copilot" autocomplete="off"/>
            </div>
            <div>
              <label class="te-label" for="rtCategory">Category</label>
              <input class="te-input" type="text" id="rtCategory" placeholder="e.g. Code &amp; Dev, AI Writing"/>
            </div>
            <div>
              <label class="te-label" for="rtUrl">URL / Access Link</label>
              <input class="te-input" type="text" id="rtUrl" placeholder="https://…"/>
            </div>
            <div>
              <label class="te-label" for="rtIcon">Icon <span class="te-hint">(emoji)</span></label>
              <input class="te-input" type="text" id="rtIcon" placeholder="🤖" maxlength="8"/>
            </div>
            <div>
              <label class="te-label" for="rtOutputType">Output Type</label>
              <input class="te-input" type="text" id="rtOutputType" placeholder="e.g. code, report, email"/>
            </div>
          </div>

          <div class="te-form-full">
            <label class="te-label" for="rtDescription">Description</label>
            <textarea class="te-textarea" id="rtDescription" rows="3" placeholder="What does this tool do? 1-3 sentences."></textarea>
          </div>

          <div class="te-form-grid">
            <div>
              <label class="te-label" for="rtBestFor">Best For <span class="te-hint">(comma-separated)</span></label>
              <textarea class="te-textarea" id="rtBestFor" rows="2" placeholder="e.g. writing emails, summarising docs"></textarea>
            </div>
            <div>
              <label class="te-label" for="rtNotFor">Not For <span class="te-hint">(comma-separated)</span></label>
              <textarea class="te-textarea" id="rtNotFor" rows="2" placeholder="e.g. real-time data, legal advice"></textarea>
            </div>
            <div>
              <label class="te-label" for="rtStrongSignals">Strong Signals <span class="te-hint">(comma-separated)</span></label>
              <textarea class="te-textarea" id="rtStrongSignals" rows="2" placeholder="e.g. write code, debug, generate function"></textarea>
            </div>
            <div>
              <label class="te-label" for="rtWeakSignals">Weak Signals <span class="te-hint">(comma-separated)</span></label>
              <textarea class="te-textarea" id="rtWeakSignals" rows="2" placeholder="e.g. automate, productivity"></textarea>
            </div>
          </div>

          <div class="te-form-full">
            <label class="te-label" for="rtRoles">Target Roles <span class="te-hint">(comma-separated)</span></label>
            <input class="te-input" type="text" id="rtRoles" placeholder="e.g. Developer, Business Analyst"/>
          </div>

          <div class="te-checkbox-row">
            <input type="checkbox" id="rtIsInternal"/>
            <label for="rtIsInternal">Internal tool (not publicly accessible)</label>
          </div>

          <!-- Additional Registry Columns -->
          <div class="te-section-title" style="margin-top:20px;margin-bottom:12px;">Additional Registry Columns</div>
          <div class="te-form-grid">
            <div>
              <label class="te-label" for="rtToolFamily">Tool Family</label>
              <input class="te-input" type="text" id="rtToolFamily" data-rd-key="tool_family" placeholder="e.g. Microsoft, Google"/>
            </div>
            <div>
              <label class="te-label" for="rtSpecialistLevel">Specialist Level</label>
              <input class="te-input" type="text" id="rtSpecialistLevel" data-rd-key="specialist_level" placeholder="e.g. Beginner, Advanced"/>
            </div>
            <div>
              <label class="te-label" for="rtLaunchStatus">Launch Status</label>
              <input class="te-input" type="text" id="rtLaunchStatus" data-rd-key="launch_status" placeholder="e.g. Live, Beta, Planned"/>
            </div>
            <div>
              <label class="te-label" for="rtSourceTabs">Source Tabs</label>
              <input class="te-input" type="text" id="rtSourceTabs" data-rd-key="source_tabs" placeholder="e.g. Sheet1, Sheet2"/>
            </div>
            <div>
              <label class="te-label" for="rtAllowsClientData">Allows Client Data</label>
              <input class="te-input" type="text" id="rtAllowsClientData" data-rd-key="allows_client_data" placeholder="e.g. Yes, No, Conditional"/>
            </div>
            <div>
              <label class="te-label" for="rtRequiresPrompt">Requires Prompt</label>
              <input class="te-input" type="text" id="rtRequiresPrompt" data-rd-key="requires_prompt" placeholder="e.g. Yes, No"/>
            </div>
            <div>
              <label class="te-label" for="rtIsPromptRequired">Is Prompt Required</label>
              <input class="te-input" type="text" id="rtIsPromptRequired" data-rd-key="is_prompt_required" placeholder="e.g. Yes, No"/>
            </div>
            <div>
              <label class="te-label" for="rtUrlOrNote">URL or Note</label>
              <input class="te-input" type="text" id="rtUrlOrNote" data-rd-key="url_or_note" placeholder="Additional URL or access note"/>
            </div>
          </div>
          <div class="te-form-full">
            <label class="te-label" for="rtPrimaryJob">Primary Job</label>
            <input class="te-input" type="text" id="rtPrimaryJob" data-rd-key="primary_job" placeholder="e.g. Code generation, Document summarisation"/>
          </div>
          <div class="te-form-grid">
            <div>
              <label class="te-label" for="rtUseWhen">Use When <span class="te-hint">(when to use this tool)</span></label>
              <textarea class="te-textarea" id="rtUseWhen" data-rd-key="use_when" rows="2" placeholder="Describe when this tool is ideal…"></textarea>
            </div>
            <div>
              <label class="te-label" for="rtAvoidWhen">Avoid When <span class="te-hint">(when not to use)</span></label>
              <textarea class="te-textarea" id="rtAvoidWhen" data-rd-key="avoid_when" rows="2" placeholder="Describe when to avoid this tool…"></textarea>
            </div>
            <div>
              <label class="te-label" for="rtTypicalInputs">Typical Inputs</label>
              <textarea class="te-textarea" id="rtTypicalInputs" data-rd-key="typical_inputs" rows="2" placeholder="e.g. Plain text, code, documents…"></textarea>
            </div>
            <div>
              <label class="te-label" for="rtTypicalOutputs">Typical Outputs</label>
              <textarea class="te-textarea" id="rtTypicalOutputs" data-rd-key="typical_outputs" rows="2" placeholder="e.g. Code snippet, summary, report…"></textarea>
            </div>
          </div>
          <div class="te-form-full">
            <label class="te-label" for="rtPromptStrategy">Prompt Strategy</label>
            <textarea class="te-textarea" id="rtPromptStrategy" data-rd-key="prompt_strategy" rows="2" placeholder="Recommended prompting approach…"></textarea>
          </div>
          <div class="te-form-full">
            <label class="te-label" for="rtNoPromptReason">No Prompt Reason</label>
            <textarea class="te-textarea" id="rtNoPromptReason" data-rd-key="no_prompt_reason" rows="2" placeholder="Why no prompt is needed (if applicable)…"></textarea>
          </div>
          <div class="te-form-full">
            <label class="te-label" for="rtDecisionNotes">Decision Notes</label>
            <textarea class="te-textarea" id="rtDecisionNotes" data-rd-key="decision_notes" rows="2" placeholder="Internal notes about tool selection decisions…"></textarea>
          </div>
          <div class="te-form-full">
            <label class="te-label" for="rtDescContent">Desc Content <span class="te-hint">(extended description)</span></label>
            <textarea class="te-textarea" id="rtDescContent" data-rd-key="Desc_Content" rows="3" placeholder="Extended description or content notes…"></textarea>
          </div>

          <!-- Knowledge file upload section — always at the bottom, matching Edit Tool -->
          <div class="te-section-title" style="margin-top:18px;margin-bottom:10px;">Uploaded Knowledge Files</div>
          <div id="rtUploadedFiles" style="margin-bottom:16px;">
            <div style="font-size:12px;color:#9ca3af;font-style:italic;">Save the tool first to attach knowledge files.</div>
          </div>
          <div class="te-section-title" style="margin-top:4px;margin-bottom:12px;">Upload New Document <span class="te-hint">(PDF, DOCX, PPTX, TXT — extracts &amp; pre-fills fields)</span></div>
          <div class="te-file-zone" id="rtFileZone">
            <div class="te-file-zone-icon">📄</div>
            <div class="te-file-zone-title">Drop files here or <button type="button" id="btnBrowseToolFiles" style="background:none;border:none;color:#2563eb;cursor:pointer;font-weight:700;font-family:inherit;font-size:inherit;padding:0;">browse</button></div>
            <div class="te-file-zone-sub">PDF, DOCX, PPTX, TXT — agent will extract info and pre-fill the form fields above</div>
          </div>
          <div id="rtExtractStatus" style="display:none;margin-top:8px;font-size:12px;padding:10px 14px;border-radius:8px;background:var(--bg-secondary);border:1px solid var(--border);"></div>
          <div id="rtFileChips" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;"></div>
          <input type="file" id="rtFileInput" multiple accept=".pdf,.docx,.pptx,.txt" style="display:none"/>

        </div>
      </div>

      <!-- FILE UPLOAD PANEL (Excel / bulk upload) -->
      <div class="te-panel" data-rtpanel="fileupload" style="display:none;">
        <div style="padding:24px 20px;">

          <div class="te-edit-note" style="background:#eff6ff;border-color:#bfdbfe;color:#1e40af;">
            📂 <strong>Bulk upload</strong> — upload an Excel file (.xlsx) to replace or extend the AI Tools Registry.
          </div>

          <div id="rtBulkDropZone" style="border:2px dashed var(--border);border-radius:12px;padding:32px 20px;text-align:center;cursor:pointer;transition:border-color .2s,background .2s;margin-top:16px;">
            <div style="font-size:36px;margin-bottom:8px;">📊</div>
            <div style="font-size:14px;font-weight:600;color:var(--text2);margin-bottom:4px;">Drop your Excel file here</div>
            <div style="font-size:12px;color:var(--text3);margin-bottom:14px;">or click to browse — .xlsx files only</div>
            <button class="btn btn-secondary" id="btnBrowseBulkTools" type="button" style="font-size:12px;padding:6px 14px;">Browse File</button>
            <input type="file" id="rtBulkFileInput" accept=".xlsx" style="display:none"/>
          </div>

          <div id="rtBulkFileInfo" style="display:none;align-items:center;gap:10px;padding:10px 14px;border-radius:8px;background:var(--bg-secondary);border:1px solid var(--border);margin-top:12px;">
            <span style="font-size:13px;flex:1;" id="rtBulkFileName"></span>
            <button id="rtBulkClearBtn" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:14px;padding:2px 4px;" title="Remove">✕</button>
          </div>

          <div style="margin-top:14px;padding:10px 14px;border-radius:8px;background:var(--bg-secondary);border:1px solid var(--border);font-size:12px;color:var(--text3);line-height:1.6;">
            Required columns: <code>tool_name</code>, <code>description</code>, <code>best_for</code>,
            <code>not_for</code>, <code>category</code>, <code>url</code>
          </div>

          <div id="rtBulkStatus" style="display:none;margin-top:12px;padding:10px 14px;border-radius:8px;font-size:13px;"></div>

        </div>
      </div>

    </div><!-- /.te-body -->

    <!-- Footer -->
    <div class="te-footer">
      <div class="te-footer-left">
        <button class="te-btn te-btn-secondary" id="btnCancelRegisterTool">Cancel</button>
      </div>
      <div class="te-footer-right" id="rtFooterRight">
        <button class="te-btn te-btn-primary" id="btnSaveRegisterTool">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Tool
        </button>
      </div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════
     CLARIFICATION DIALOG MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="clarOverlay" role="dialog" aria-modal="true" aria-labelledby="clarModalTitle">
  <div class="modal" style="max-width:600px;">

    <div class="modal-header">
      <h3 class="modal-title" id="clarModalTitle">💬 Quick Clarification</h3>
      <button class="modal-close" id="clarSkipBtn" title="Skip and generate anyway" aria-label="Skip">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="modal-body">
      <p style="margin:0 0 12px;color:var(--text3);font-size:13px;line-height:1.5;">
        A bit more detail will help us recommend the right tool. Answer what you can — leave blank to skip.
      </p>

      <div id="clarBody"></div>
    </div>

    <div class="modal-footer" style="padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:10px;">
      <button class="btn btn-secondary" id="clarSkipBtn2">
        Cancel
      </button>
      <button class="btn btn-primary" id="clarSubmitBtn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Submit &amp; Generate
      </button>
    </div>

  </div>
</div>

<!-- ══ JS FILES ══
     Load order matters:
     1. ui.js      — shared helpers (escapeHtml, showToast, goToStep, etc.)
     2. app.js     — main app logic (uses helpers from ui.js + calls API)
     3. promptlibrary.js — standalone prompt library
-->
<!-- ══════════════════════════════════════
     ANALYTICS DASHBOARD MODAL
══════════════════════════════════════ -->
<div class="an-overlay" id="anOverlay"></div>
<div class="an-modal" id="anModal">

  <!-- Header -->
  <div class="an-header">
    <div class="an-header-left">
      <div class="an-header-icon">📊</div>
      <div>
        <div class="an-header-title">Usage Analytics</div>
        <div class="an-header-sub">Real-time usage insights across all roles &amp; sessions</div>
      </div>
    </div>
    <div class="an-header-right">
      <button class="an-close-btn" id="anCloseBtn" aria-label="Close">✕</button>
    </div>
  </div>

  <!-- Controls Bar -->
  <div class="an-controls">
    <span class="an-controls-label">Period</span>
    <div class="an-period-tabs">
      <button class="an-period-tab active" data-period="day">Today</button>
      <button class="an-period-tab" data-period="week">This Week</button>
      <button class="an-period-tab" data-period="month">This Month</button>
    </div>
    <div class="an-divider"></div>
    <span class="an-controls-label">Filter by Role</span>
    <select class="an-role-select" id="anRoleSelect">
      <option value="all">All Roles</option>
      <option value="general">General</option>
      <option value="Consultant">Consultant / Manager</option>
      <option value="Executive">Executive / Director</option>
      <option value="Developer">Developer / Technical</option>
      <option value="Analyst">Business Analyst</option>
      <option value="Sales">Sales / BD</option>
      <option value="Marketing">Marketing / Comms</option>
      <option value="HR">HR / People Ops</option>
      <option value="Finance">Finance / Accounting</option>
    </select>
    <button class="an-refresh-btn" id="anRefreshBtn">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      Refresh
    </button>
  </div>

  <!-- Dashboard Body -->
  <div class="an-body" id="anBody">
    <!-- Populated dynamically by analytics.js -->
    <div class="an-loading">
      <div class="an-spinner"></div>
      <span>Loading analytics…</span>
    </div>
  </div>

</div>

<!-- ══════════════════════════════════════
     FEEDBACK FORM MODAL
══════════════════════════════════════ -->
<div class="fb-overlay" id="fbOverlay"></div>
<div class="fb-form-modal" id="fbFormModal">
  <div class="fb-form-header">
    <div class="fb-form-header-left">
      <div class="fb-form-header-icon">💬</div>
      <div>
        <div class="fb-form-header-title">Share Your Feedback</div>
        <div class="fb-form-header-sub">Help us improve your experience</div>
      </div>
    </div>
    <button class="fb-close-btn" id="fbCloseBtn" aria-label="Close">✕</button>
  </div>
  <div class="fb-form-body" id="fbFormBody"></div>
  <div class="fb-success" id="fbFormSuccess">
    <div class="fb-success-icon">🎉</div>
    <div class="fb-success-title">Thank you for your feedback!</div>
    <div class="fb-success-sub">Your response has been recorded and will help us improve.</div>
  </div>
</div>

<!-- ══════════════════════════════════════
     FEEDBACK VIEWER MODAL
══════════════════════════════════════ -->
<div class="fbv-overlay" id="fbvOverlay"></div>
<div class="fbv-modal" id="fbvModal">

  <div class="fbv-header">
    <div class="fbv-header-left">
      <div class="fbv-header-icon">📋</div>
      <div>
        <div class="fbv-header-title">Feedback Dashboard</div>
        <div class="fbv-header-sub">All user feedback — ratings, comments &amp; issue types</div>
      </div>
    </div>
    <div class="fbv-header-right">
      <button class="fbv-close-btn" id="fbvCloseBtn" aria-label="Close">✕</button>
    </div>
  </div>

  <div class="fbv-controls">
    <span class="fbv-controls-label">Search</span>
    <input class="fbv-search" id="fbvSearch" type="text" placeholder="Search email, comment…" />
    <span class="fbv-controls-label">Rating</span>
    <select class="fbv-rating-filter" id="fbvRatingFilter">
      <option value="0">All Ratings</option>
      <option value="5">5 ★ Excellent</option>
      <option value="4">4 ★ Very Good</option>
      <option value="3">3 ★ Good</option>
      <option value="2">2 ★ Fair</option>
      <option value="1">1 ★ Poor</option>
    </select>
    <button class="fbv-refresh-btn" id="fbvRefreshBtn">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      Refresh
    </button>
  </div>

  <div class="fbv-body" id="fbvBody">
    <div class="fbv-loading">
      <div class="fbv-spinner"></div>
      <span>Loading feedbacks…</span>
    </div>
  </div>

</div>

<!-- ══════════════════════════════════════
     TOOL CHANGE LOG MODAL
══════════════════════════════════════ -->
<div class="tcl-overlay" id="tclOverlay"></div>
<div class="tcl-modal" id="tclModal">

  <div class="tcl-header">
    <div class="tcl-header-left">
      <div class="tcl-header-icon">🔧</div>
      <div>
        <div class="tcl-header-title">Tool Change Log</div>
        <div class="tcl-header-sub">All tool registrations, edits, and deletions</div>
      </div>
    </div>
    <div class="tcl-header-right">
      <button class="tcl-close-btn" id="tclCloseBtn" aria-label="Close">✕</button>
    </div>
  </div>

  <div class="tcl-controls">
    <span class="tcl-controls-label">Search tool</span>
    <input class="tcl-search" id="tclSearch" type="text" placeholder="Filter by tool name…" />
    <button class="tcl-refresh-btn" id="tclRefreshBtn">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      Refresh
    </button>
  </div>

  <div class="tcl-body" id="tclBody">
    <div class="tcl-loading">
      <div class="tcl-spinner"></div>
      <span>Loading change log…</span>
    </div>
  </div>

  <div class="tcl-footer" id="tclFooter" style="display:none;">
    <button class="tcl-page-btn" id="tclPrevBtn">← Prev</button>
    <span class="tcl-page-info" id="tclPageInfo"></span>
    <button class="tcl-page-btn" id="tclNextBtn">Next →</button>
  </div>

</div>

<!-- ══════════════════════════════════════
     TOOL EDITOR MODAL
══════════════════════════════════════ -->
<div class="te-overlay" id="teOverlay"></div>
<div class="te-modal" id="teModal">

  <div class="te-header">
    <div class="te-header-left">
      <div class="te-header-icon" id="teHeaderIcon">🤖</div>
      <div>
        <div class="te-header-name" id="teHeaderName">Tool</div>
        <div class="te-header-cat"  id="teHeaderCat"></div>
      </div>
    </div>
    <div class="te-header-right">
      <span class="te-header-badge" id="teHeaderBadge" style="display:none;align-items:center;"></span>
      <button class="te-close-btn" id="teCloseBtn" aria-label="Close">✕</button>
    </div>
  </div>

  <div class="te-tabs">
    <button class="te-tab active" data-tab="view">📋 View Details</button>
    <button class="te-tab"        data-tab="edit">✏️ Edit Tool</button>
  </div>

  <div class="te-body">

    <!-- VIEW PANEL -->
    <div class="te-panel active" data-panel="view" id="teViewPanel">
      <div style="padding:40px;text-align:center;color:#6b7280;font-size:13px;">Loading…</div>
    </div>

    <!-- EDIT PANEL — content is rendered dynamically by tool_editor.js _populateEditForm() -->
    <div class="te-panel" data-panel="edit" id="teEditPanel">
      <div class="te-edit-body"></div>
    </div>

  </div>

  <div class="te-footer">
    <div class="te-footer-left">
      <button class="te-btn te-btn-danger" id="teDeleteBtn">🗑 Delete Tool</button>
    </div>
    <div class="te-footer-right">
      <button class="te-btn te-btn-secondary" id="teCancelBtn">Cancel</button>
      <button class="te-btn te-btn-primary"   id="teSaveBtn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Save Changes
      </button>
    </div>
  </div>

</div>

<script src="/static/js/ui.js"></script>
<script src="/static/js/app.js"></script>
<script src="/static/js/promptlib.js"></script>
<script src="/static/js/scenario_library.js"></script>
<script src="/static/js/file_upload.js"></script>
<script src="/static/js/analytics.js"></script>
<script src="/static/js/feedback.js"></script>
<script src="/static/js/tool_editor.js"></script>
<script src="/static/js/admin_scenarios.js"></script>
<script src="/static/js/auth.js"></script>

</div><!-- /#appShell -->
</body>
</html>